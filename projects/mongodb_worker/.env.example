# ---- MongoDB ----
# 注:之前的 MONOOB_DATABASE_URL 是 MONGODB_ 的笔误,这里用正名
MONGODB_DATABASE_URL=xxxxxxxx
# 默认从 URL 里取 DB,若要显式覆盖再填:
# MONGODB_DB=aecapllc-prod
MONGODB_COLL=ResearchReportRecord

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxxx
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=aecapllc
AWS_S3_PREFIX=research-reports/parsed

# ---- MinerU ----
MINERU_API_URL=http://127.0.0.1:8000
MINERU_BACKEND=hybrid-auto-engine

# ---- Worker ----
BATCH_SIZE=5
LOCK_TTL_SECONDS=3600
MAX_RETRIES=3
POLL_IDLE_SECONDS=30
# LibreOffice 可执行;macOS: /Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_BIN=soffice
